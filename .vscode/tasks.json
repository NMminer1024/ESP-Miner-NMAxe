{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Web (Angular)",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}/src/web/axe-os"
            },
            "problemMatcher": [
                "$tsc"
            ],
            "detail": "Build web assets only"
        },
        {
            "label": "Build SPIFFS",
            "type": "shell",
            "command": "platformio",
            "args": [
                "run",
                "-e",
                "NMAxe",
                "--target",
                "buildfs"
            ],
            "problemMatcher": [],
            "detail": "Build SPIFFS"
        },
        {
            "label": "Upload SPIFFS",
            "type": "shell",
            "command": "platformio",
            "args": [
                "run",
                "-e",
                "NMAxe",
                "--target",
                "uploadfs"
            ],
            "problemMatcher": [],
            "detail": "Upload SPIFFS"
        },
        {
            "label": "Upload ESP32 Firmware",
            "type": "shell",
            "command": "platformio",
            "args": [
                "run",
                "-e",
                "NMAxe",
                "--target",
                "upload"
            ],
            "problemMatcher": [],
            "detail": "Build and upload firmware only"
        },
        {
            "label": "Build ESP32 Firmware",
            "type": "shell",
            "command": "platformio",
            "args": [
                "run",
                "-e",
                "NMAxe"
            ],
            "problemMatcher": [],
            "detail": "Build firmware only (no web build)",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build All and upload",
            "dependsOn": [
                "Upload SPIFFS",
                "Upload ESP32 Firmware"
            ],
            "dependsOrder": "sequence"
        },
        {
            "label": "Calculate Web Files Size",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-File", "calculate_web_size.ps1"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}